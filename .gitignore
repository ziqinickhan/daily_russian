# Xcode - breakpoints
*.xcodeproj/xcshareddata/xcdebugger/

# Swift Package Manager
.swiftpm/
Package.resolved

# CocoaPods (if we ever use it)
Pods/

# Secrets & config
*.xcconfig
!Sample.xcconfig
Secrets/
Config/Debug.xcconfig
Config/Release.xcconfig

# macOS
.DS_Store
*.swp
*~

# Core Data - these are generated at build time
*.xcdatamodeld/*.xcdatamodel/contents
